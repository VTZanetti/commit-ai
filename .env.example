# Chave de API do Open Router
OPEN_ROUTER_API_KEY=

# Modelo do Open Router
OPEN_ROUTER_MODEL=

# Respeitar regras do .gitignore ao processar arquivos
# Use "true" para ignorar arquivos gitignored, "false" para incluí-los
IGNORE_GITIGNORED_FILES=true

# Máximo de caracteres para ler de cada arquivo novo/não rastreado
# Arquivos maiores serão truncados nas primeiras 30 linhas / 0 = ilimitado / Recomendado = 2000
MAX_FILE_CHARS=2000

# Número máximo de arquivos novos/não rastreados para processar
# Use 0 para ilimitado
MAX_TOTAL_FILES=0

# Tamanho máximo do diff total em caracteres para enviar à IA
# Use 0 para ilimitado
MAX_DIFF_SIZE=0