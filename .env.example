# Open Router API Configuration
OPEN_ROUTER_API_KEY=your_api_key_here
OPEN_ROUTER_MODEL=openrouter/auto

# Otimização para APIs gratuitas com limite de tokens
# Ativa processamento em 2 etapas: resume cada arquivo individualmente
# antes de gerar o commit final (ideal para IAs gratuitas)
USE_TWO_STEP_PROCESSING=true

# Tamanho máximo do diff de cada arquivo ao resumir (em caracteres)
# Valores menores = menos tokens por requisição
MAX_CHUNK_SIZE=8000

# Tamanho máximo de cada arquivo novo antes de truncar (em caracteres)
MAX_FILE_CHARS=2000

# Número máximo de arquivos novos a processar
MAX_TOTAL_FILES=50

# Tamanho máximo total do diff combinado (em caracteres)
# Se ultrapassar, será truncado
MAX_DIFF_SIZE=100000

# Ignora arquivos listados no .gitignore
IGNORE_GITIGNORED_FILES=true
